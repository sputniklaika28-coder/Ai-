# ──────────────────────────────────────────
# Browser Use 推論エンジン
# ──────────────────────────────────────────
# プロバイダー: local / openai / anthropic
BROWSER_USE_PROVIDER=local

# Browser Use が使用するモデル（空欄=サーバー側のデフォルト）
# local  → LM Studio にロード済みのモデルを自動使用
# openai → gpt-4o / gpt-4o-mini
# anthropic → claude-sonnet-4-20250514
BROWSER_USE_MODEL=

# ──────────────────────────────────────────
# ローカル LLM（LM Studio / Ollama 等）
# ──────────────────────────────────────────
LM_STUDIO_URL=http://localhost:1234

# ──────────────────────────────────────────
# VLM（Vision Language Model — Canvas解析用）
# ──────────────────────────────────────────
# local = LM Studio のマルチモーダルモデルを使用
# openai = GPT-4o Vision API を使用
VLM_PROVIDER=local
VLM_MODEL=

# ──────────────────────────────────────────
# クラウド API キー（任意 — ローカルのみなら設定不要）
# ──────────────────────────────────────────
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# ──────────────────────────────────────────
# VLM OS Agent（アドオン: addons/vlm_os_agent）
# 既に起動中のデスクトップアプリを VLM で視覚操作する
# 完全ローカル（LM Studio）で動作。pip install -e .[vlm-agent] が必要。
# ──────────────────────────────────────────
# 対象ウィンドウタイトル（正規表現）
VLM_AGENT_TARGET_WINDOW=ココフォリア

# エージェントループのポーリング間隔（ミリ秒）
VLM_AGENT_POLL_MS=500

# 座標キャッシュ TTL（秒）。0 で無期限
VLM_AGENT_CACHE_TTL=3600

# Set-of-Mark（番号札オーバーレイ）。true にする場合は
# pip install -e .[vlm-agent-som] が必要
VLM_AGENT_SOM_ENABLED=false

# os_run_task の最大ステップ数（無限ループ防止）
VLM_AGENT_MAX_STEPS=20

# pyautogui FAILSAFE（画面四隅へのマウス移動で緊急停止）
VLM_AGENT_FAILSAFE=true

# Perceive バックエンド: none / cv / omniparser
VLM_AGENT_PERCEIVE_BACKEND=none

# ──────────────────────────────────────────
# VTT バックエンド選択（Phase 1 新機能）
# ccfolia  = CCFolia Playwright 操作（既存・デフォルト）
# foundry  = Foundry VTT REST API（ブラウザ不要）
# vision   = VLM + pyautogui 視覚制御（任意 VTT 対応）
# ──────────────────────────────────────────
VTT_BACKEND=ccfolia

# ──────────────────────────────────────────
# Foundry VTT アダプター（VTT_BACKEND=foundry の場合）
# foundryvtt-rest-api モジュールが Foundry に導入済みであること
# ──────────────────────────────────────────
FOUNDRY_URL=http://localhost:30000
FOUNDRY_API_KEY=

# ──────────────────────────────────────────
# VisionVTT アダプター（VTT_BACKEND=vision の場合）
# pip install -e .[vlm-agent] が必要
# ──────────────────────────────────────────
# 対象ウィンドウタイトル（正規表現）— 空欄でプライマリモニタ全体
VISION_VTT_WINDOW=

# 1グリッドセルのピクセルサイズ
VISION_VTT_GRID_SIZE=100

# チャットログのキャプチャ領域（省略可）: left,top,right,bottom
# 例: 0,600,400,1080
VISION_VTT_CHAT_LOG_REGION=

# ボードのキャプチャ領域（省略可）: left,top,right,bottom
VISION_VTT_BOARD_REGION=

# VLM 操作の最大ステップ数
VISION_VTT_MAX_STEPS=6

# ──────────────────────────────────────────
# ComfyUI / 立ち絵ジェネレーター
# image_generator + portrait_generator アドオンが共通参照
# ──────────────────────────────────────────
# ComfyUI サーバー（ローカル既定）
COMFYUI_HOST=127.0.0.1
COMFYUI_PORT=8188

# 接続ヘルスチェックのタイムアウト秒
COMFYUI_TIMEOUT=3.0

# 生成完了までの最大待機秒
COMFYUI_GEN_TIMEOUT=120

# 利用するチェックポイント名（空欄なら ComfyUI に登録された最初の物を自動選択）
# 例: COMFYUI_CHECKPOINT=animagine-xl-3.1.safetensors
COMFYUI_CHECKPOINT=

# サンプラー設定
COMFYUI_STEPS=20
COMFYUI_CFG=7.0

# 生成画像のデフォルト寸法。0 ならスタイルプリセット既定値（立ち絵なら 768x1024）
COMFYUI_WIDTH=0
COMFYUI_HEIGHT=0

# 立ち絵・トークン保存先（プロジェクト相対 or 絶対）
PORTRAIT_OUTPUT_DIR=generated_images

# 円形トークン: 一辺ピクセル数 / 枠色 R,G,B
PORTRAIT_TOKEN_SIZE=256
PORTRAIT_TOKEN_BORDER=200,160,60
