# ──────────────────────────────────────────
# Browser Use 推論エンジン
# ──────────────────────────────────────────
# プロバイダー: local / openai / anthropic
BROWSER_USE_PROVIDER=local

# Browser Use が使用するモデル（空欄=サーバー側のデフォルト）
# local  → LM Studio にロード済みのモデルを自動使用
# openai → gpt-4o / gpt-4o-mini
# anthropic → claude-sonnet-4-20250514
BROWSER_USE_MODEL=

# ──────────────────────────────────────────
# ローカル LLM（LM Studio / Ollama 等）
# ──────────────────────────────────────────
LM_STUDIO_URL=http://localhost:1234

# ──────────────────────────────────────────
# VLM（Vision Language Model — Canvas解析用）
# ──────────────────────────────────────────
# local = LM Studio のマルチモーダルモデルを使用
# openai = GPT-4o Vision API を使用
VLM_PROVIDER=local
VLM_MODEL=

# ──────────────────────────────────────────
# クラウド API キー（任意 — ローカルのみなら設定不要）
# ──────────────────────────────────────────
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# ──────────────────────────────────────────
# VLM OS Agent（アドオン: addons/vlm_os_agent）
# 既に起動中のデスクトップアプリを VLM で視覚操作する
# 完全ローカル（LM Studio）で動作。pip install -e .[vlm-agent] が必要。
# ──────────────────────────────────────────
# 対象ウィンドウタイトル（正規表現）
VLM_AGENT_TARGET_WINDOW=ココフォリア

# エージェントループのポーリング間隔（ミリ秒）
VLM_AGENT_POLL_MS=500

# 座標キャッシュ TTL（秒）。0 で無期限
VLM_AGENT_CACHE_TTL=3600

# Set-of-Mark（番号札オーバーレイ）。true にする場合は
# pip install -e .[vlm-agent-som] が必要
VLM_AGENT_SOM_ENABLED=false

# os_run_task の最大ステップ数（無限ループ防止）
VLM_AGENT_MAX_STEPS=20

# pyautogui FAILSAFE（画面四隅へのマウス移動で緊急停止）
VLM_AGENT_FAILSAFE=true

# Perceive バックエンド: none / cv / omniparser
VLM_AGENT_PERCEIVE_BACKEND=none
