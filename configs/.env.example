# ──────────────────────────────────────────
# Browser Use 推論エンジン（いずれか一方を設定）
# ──────────────────────────────────────────
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# Browser Use が使用するクラウドモデル
BROWSER_USE_MODEL=gpt-4o
# BROWSER_USE_MODEL=claude-sonnet-4-20250514

# ──────────────────────────────────────────
# ローカル LLM（既存 TRPG ロジック用）
# ──────────────────────────────────────────
LM_STUDIO_URL=http://localhost:1234

# ──────────────────────────────────────────
# VLM（Vision Language Model — Canvas解析用）
# ──────────────────────────────────────────
VLM_PROVIDER=openai
# VLM_PROVIDER=local
VLM_MODEL=gpt-4o
